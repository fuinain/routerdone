+    idleAfterProductiveMs: toMs(streamOverrides.idleAfterProductiveMs, base.stream.idleAfterProductiveMs),
+    totalBudgetMs: toMs(streamOverrides.totalBudgetMs, base.stream.totalBudgetMs),
+  };
